<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_lg"
        android:background="@color/background_white">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="@dimen/icon_size_md"
            android:layout_height="@dimen/icon_size_md"
            android:src="@android:drawable/ic_menu_back"
            android:contentDescription="Back"
            android:tint="@color/primary_blue"
            android:layout_marginEnd="@dimen/spacing_md" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:textColor="@color/primary_blue" />
    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/assessment_result"
                style="@style/HeadingLarge"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Patient ID Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/background_light"
                app:cardCornerRadius="@dimen/corner_radius_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/avatar_size_lg"
                        android:layout_height="@dimen/avatar_size_lg"
                        android:src="@android:drawable/ic_dialog_info"
                        android:contentDescription="Patient"
                        android:tint="@color/primary_blue"
                        android:layout_marginEnd="@dimen/spacing_lg" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Amara Okafor"
                            style="@style/BodyText"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/patient_id"
                            style="@style/LabelText"
                            android:layout_marginTop="@dimen/spacing_sm" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MED-2024-0847"
                            style="@style/BodyText" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Risk Level Alert -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/alert_red_light"
                app:cardCornerRadius="@dimen/corner_radius_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/icon_size_lg"
                            android:layout_height="@dimen/icon_size_lg"
                            android:src="@android:drawable/ic_dialog_alert"
                            android:contentDescription="Alert"
                            android:tint="@color/alert_red"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/high_risk"
                            style="@style/HeadingSmall"
                            android:textColor="@color/alert_red" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/high_risk_pregnancy"
                        style="@style/BodyText"
                        android:textColor="@color/alert_red"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="@dimen/spacing_xs"
                            android:layout_height="@dimen/spacing_lg"
                            android:background="@color/alert_red"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Risk Factors Detected:"
                                style="@style/LabelText"
                                android:textColor="@color/alert_red" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="• Elevated blood pressure\n• Gestational diabetes markers\n• Previous complications"
                                style="@style/BodyText"
                                android:textColor="@color/alert_red"
                                android:layout_marginTop="@dimen/spacing_sm" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recommendation Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/spacing_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/recommendation"
                    style="@style/LabelText"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/background_light"
                    app:cardCornerRadius="@dimen/corner_radius_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="@dimen/icon_size_lg"
                            android:layout_height="@dimen/icon_size_lg"
                            android:src="@android:drawable/ic_dialog_info"
                            android:contentDescription="Recommendation"
                            android:tint="@color/alert_red"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/refer_to_doctor_24h"
                            style="@style/BodyText"
                            android:textColor="@color/alert_red" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Vital Signs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/spacing_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="VITAL SIGNS SNAPSHOT"
                    style="@style/LabelText"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_md"
                        app:cardBackgroundColor="@color/background_light"
                        app:cardCornerRadius="@dimen/corner_radius_lg">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="@dimen/spacing_lg">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="145/92"
                                style="@style/HeadingSmall"
                                android:textColor="@color/alert_red" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BLOOD PRESSURE"
                                style="@style/LabelText"
                                android:layout_marginTop="@dimen/spacing_sm" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/background_light"
                        app:cardCornerRadius="@dimen/corner_radius_lg">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="@dimen/spacing_lg">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="94%"
                                style="@style/HeadingSmall"
                                android:textColor="@color/success_green" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/oxygen_sat"
                                style="@style/LabelText"
                                android:layout_marginTop="@dimen/spacing_sm" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <!-- AI Confidence -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/spacing_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_confidence"
                    style="@style/LabelText"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ProgressBar
                        android:layout_width="0dp"
                        android:layout_height="@dimen/spacing_lg"
                        android:layout_weight="1"
                        android:progress="87"
                        android:progressDrawable="@drawable/progress_bar_background"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="87%"
                        style="@style/BodyText"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Action Buttons -->
            <Button
                android:id="@+id/escalateButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/escalate_case"
                style="@style/AlertButton"
                android:layout_marginBottom="@dimen/spacing_md" />

            <Button
                android:id="@+id/doneButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/done"
                style="@style/PrimaryButton"
                android:layout_marginBottom="@dimen/spacing_xl" />

            <!-- Status Text -->
            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/status_ready"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/text_secondary"
                android:gravity="center" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
