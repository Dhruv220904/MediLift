<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_lg"
        android:background="@color/background_white">

        <ImageView
            android:layout_width="@dimen/icon_size_md"
            android:layout_height="@dimen/icon_size_md"
            android:src="@android:drawable/ic_menu_back"
            android:contentDescription="@string/app_name"
            android:tint="@color/primary_blue"
            android:layout_marginEnd="@dimen/spacing_md" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:textColor="@color/primary_blue" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/rounded_background"
            android:padding="@dimen/spacing_sm">

            <View
                android:layout_width="@dimen/spacing_sm"
                android:layout_height="@dimen/spacing_sm"
                android:background="@drawable/circle_background"
                android:backgroundTint="@color/offline_indicator" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFFLINE"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/text_dark"
                android:layout_marginStart="@dimen/spacing_sm" />
        </LinearLayout>
    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Morning Shift Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/morning_shift"
                style="@style/LabelText"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/daily_focus"
                style="@style/HeadingLarge"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Visits Today -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08"
                        android:textSize="@dimen/text_large_heading"
                        android:textStyle="bold"
                        android:textColor="@color/primary_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/visits_today"
                        style="@style/LabelText" />
                </LinearLayout>
            </LinearLayout>

            <!-- Alert Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/alert_red_light"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/icon_size_md"
                            android:layout_height="@dimen/icon_size_md"
                            android:src="@android:drawable/ic_dialog_alert"
                            android:contentDescription="@string/critical_intervention"
                            android:tint="@color/alert_red"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/critical_intervention"
                            style="@style/LabelText"
                            android:textColor="@color/alert_red" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/high_risk_zone"
                        style="@style/HeadingSmall"
                        android:textColor="@color/alert_red"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/vitals_recorded"
                        style="@style/SecondaryText"
                        android:textColor="@color/alert_red"
                        android:layout_marginBottom="@dimen/spacing_lg"
                        android:lineSpacingMultiplier="1.4" />

                    <Button
                        android:id="@+id/viewAlertsButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_small"
                        android:text="@string/view_alerts"
                        android:textSize="@dimen/text_sm"
                        android:textStyle="bold"
                        android:backgroundTint="@color/alert_red"
                        android:textColor="@color/text_white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Local Storage Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@android:drawable/ic_dialog_info"
                        android:contentDescription="@string/local_storage"
                        android:tint="@color/primary_blue"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/local_storage"
                        style="@style/BodyText"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/records_pending_sync"
                    style="@style/SecondaryText"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/sync_progress"
                            style="@style/LabelText" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="64%"
                            style="@style/BodyText"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/spacing_md"
                        android:progress="64"
                        android:progressDrawable="@drawable/progress_bar_background"
                        style="?android:attr/progressBarStyleHorizontal" />
                </LinearLayout>
            </LinearLayout>

            <!-- Action Buttons -->
            <Button
                android:id="@+id/addPatientButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/add_new_patient"
                style="@style/PrimaryButton"
                android:drawableStart="@android:drawable/ic_menu_add"
                android:layout_marginBottom="@dimen/spacing_md" />

            <Button
                android:id="@+id/startVisitButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/start_visit"
                style="@style/SecondaryButton"
                android:drawableStart="@android:drawable/ic_media_play"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Pending Follow-ups -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_md">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pending_follow_ups"
                    style="@style/HeadingSmall" />

                <TextView
                    android:id="@+id/seeAllFollowups"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    style="@style/LabelText" />
            </LinearLayout>

            <!-- Follow-up Cards -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/background_white"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/avatar_size_md"
                        android:layout_height="@dimen/avatar_size_md"
                        android:src="@android:drawable/ic_dialog_info"
                        android:contentDescription="Patient Avatar"
                        android:tint="@color/primary_blue"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Elena Rodriguez"
                            style="@style/BodyText"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/post_op"
                            style="@style/SecondaryText" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cardiac_check"
                            style="@style/SecondaryText" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/room_402"
                            style="@style/SecondaryText" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/overdue"
                            style="@style/LabelText"
                            android:textColor="@color/alert_red" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14:00"
                            style="@style/BodyText"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/background_white"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/avatar_size_md"
                        android:layout_height="@dimen/avatar_size_md"
                        android:src="@android:drawable/ic_dialog_info"
                        android:contentDescription="Patient Avatar"
                        android:tint="@color/primary_blue"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Samuel Mkapa"
                            style="@style/BodyText"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Insulin Calibration"
                            style="@style/SecondaryText" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rural Sector D"
                            style="@style/SecondaryText" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/scheduled"
                            style="@style/LabelText"
                            android:textColor="@color/success_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="16:30"
                            style="@style/BodyText"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Status Text -->
            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/status_ready"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="@dimen/spacing_lg" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:orientation="horizontal"
        android:background="@color/background_white"
        android:gravity="center_vertical"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/primary_blue">

            <ImageView
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:src="@android:drawable/ic_menu_home"
                android:contentDescription="@string/home"
                android:tint="@color/text_white"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/text_white"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPatients"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:src="@android:drawable/ic_dialog_info"
                android:contentDescription="@string/patients"
                android:tint="@color/text_secondary"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/patients"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAlerts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:src="@android:drawable/ic_dialog_alert"
                android:contentDescription="@string/alerts_nav"
                android:tint="@color/text_secondary"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/alerts_nav"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:src="@android:drawable/ic_menu_preferences"
                android:contentDescription="@string/settings_nav"
                android:tint="@color/text_secondary"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_nav"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
