<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_lg"
        android:background="@color/background_white">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="@dimen/icon_size_md"
            android:layout_height="@dimen/icon_size_md"
            android:src="@android:drawable/ic_menu_back"
            android:contentDescription="Back"
            android:tint="@color/primary_blue"
            android:layout_marginEnd="@dimen/spacing_md" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:textColor="@color/primary_blue" />
    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Alert Banner -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/alert_red_light"
                app:cardCornerRadius="@dimen/corner_radius_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:src="@android:drawable/ic_dialog_alert"
                        android:contentDescription="Alert"
                        android:tint="@color/alert_red"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/critical_care"
                            style="@style/LabelText"
                            android:textColor="@color/alert_red" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/referral_escalation"
                            style="@style/HeadingSmall"
                            android:textColor="@color/alert_red"
                            android:layout_marginTop="@dimen/spacing_sm" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Available Specialists -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AVAILABLE SPECIALISTS"
                style="@style/LabelText"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Specialist Card 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/background_white"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/avatar_size_lg"
                            android:layout_height="@dimen/avatar_size_lg"
                            android:src="@android:drawable/ic_dialog_info"
                            android:contentDescription="Doctor"
                            android:tint="@color/primary_blue"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dr. James Vance"
                                style="@style/BodyText"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/senior_cardiologist"
                                style="@style/SecondaryText" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/available_now"
                                style="@style/LabelText"
                                android:textColor="@color/success_green" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2.4 @string/km_away"
                                style="@style/BodyText"
                                android:layout_marginTop="@dimen/spacing_sm" />
                        </LinearLayout>
                    </LinearLayout>

                    <Button
                        android:id="@+id/callDoctorButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height_small"
                        android:text="@string/call_doctor_vance"
                        android:textSize="@dimen/text_md"
                        android:backgroundTint="@color/primary_blue"
                        android:textColor="@color/text_white"
                        android:drawableStart="@android:drawable/ic_menu_call" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Specialist Card 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/background_white"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/avatar_size_lg"
                            android:layout_height="@dimen/avatar_size_lg"
                            android:src="@android:drawable/ic_dialog_info"
                            android:contentDescription="Doctor"
                            android:tint="@color/primary_blue"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dr. Sarah Chen"
                                style="@style/BodyText"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Obstetrics & Gynecology"
                                style="@style/SecondaryText" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AVAILABLE IN 15 MIN"
                                style="@style/LabelText"
                                android:textColor="@color/primary_blue" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5.2 km away"
                                style="@style/BodyText"
                                android:layout_marginTop="@dimen/spacing_sm" />
                        </LinearLayout>
                    </LinearLayout>

                    <Button
                        android:id="@+id/callDoctorChenButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height_small"
                        android:text="Call Dr. Chen"
                        android:textSize="@dimen/text_md"
                        android:backgroundTint="@color/primary_blue"
                        android:textColor="@color/text_white"
                        android:drawableStart="@android:drawable/ic_menu_call" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Escalation Notes -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/escalation_notes"
                style="@style/LabelText"
                android:layout_marginBottom="@dimen/spacing_md" />

            <EditText
                android:id="@+id/escalationNotesInput"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="@string/describe_worsening"
                android:background="@color/background_light"
                android:padding="@dimen/spacing_lg"
                android:textSize="@dimen/text_md"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_light"
                android:gravity="top"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Confirmation Text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/background_light"
                android:padding="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_lg">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:src="@android:drawable/ic_dialog_info"
                    android:contentDescription="Info"
                    android:tint="@color/primary_blue"
                    android:layout_marginEnd="@dimen/spacing_md" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/will_alert_dispatch"
                    style="@style/SecondaryText" />
            </LinearLayout>

            <!-- Confirm Referral Button -->
            <Button
                android:id="@+id/confirmReferralButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/confirm_referral"
                style="@style/AlertButton"
                android:layout_marginBottom="@dimen/spacing_xl" />

            <!-- Status Text -->
            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/status_ready"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/text_secondary"
                android:gravity="center" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
