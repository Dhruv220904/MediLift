<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:justifyContent="space_between"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="@dimen/text_xxl"
                android:textStyle="bold"
                android:textColor="@color/primary_blue" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_background"
                android:padding="@dimen/spacing_sm">

                <View
                    android:layout_width="@dimen/spacing_sm"
                    android:layout_height="@dimen/spacing_sm"
                    android:background="@drawable/circle_background"
                    android:backgroundTint="@color/offline_indicator" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/offline_ready"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_dark"
                    android:layout_marginStart="@dimen/spacing_sm" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hero Text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/care_without_boundaries"
            style="@style/HeadingLarge"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/empowering_healthcare"
            style="@style/BodyText"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:lineSpacingMultiplier="1.5" />

        <!-- Language Selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/spacing_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_md">

                <Button
                    android:id="@+id/languageHindiButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_weight="1"
                    android:text="@string/language_hindi"
                    android:textSize="@dimen/text_md"
                    android:backgroundTint="@color/background_light"
                    android:textColor="@color/text_dark"
                    android:layout_marginEnd="@dimen/spacing_md" />

                <Button
                    android:id="@+id/languageEnglishButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_weight="1"
                    android:text="@string/language_english"
                    android:textSize="@dimen/text_md"
                    android:backgroundTint="@color/primary_blue"
                    android:textColor="@color/text_white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/languageBengaliButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_weight="1"
                    android:text="@string/language_bengali"
                    android:textSize="@dimen/text_md"
                    android:backgroundTint="@color/background_light"
                    android:textColor="@color/text_dark"
                    android:layout_marginEnd="@dimen/spacing_md" />

                <Button
                    android:id="@+id/languageTamilButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_small"
                    android:layout_weight="1"
                    android:text="@string/language_tamil"
                    android:textSize="@dimen/text_md"
                    android:backgroundTint="@color/background_light"
                    android:textColor="@color/text_dark" />
            </LinearLayout>
        </LinearLayout>

        <!-- Voice Guidance Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/background_light"
            android:padding="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_xl">

            <ImageView
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:src="@android:drawable/ic_dialog_info"
                android:contentDescription="@string/voice_guidance_label"
                android:tint="@color/primary_blue"
                android:layout_marginEnd="@dimen/spacing_md" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/voice_guidance_label"
                style="@style/BodyText" />

            <Switch
                android:id="@+id/voiceGuidanceSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- PIN Entry Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/secure_pin_entry"
            style="@style/HeadingSmall"
            android:layout_marginBottom="@dimen/spacing_md" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/enter_4_digit_code"
            style="@style/SecondaryText"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:gravity="center" />

        <!-- PIN Input Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_xl">

            <View
                android:id="@+id/pinDot1"
                android:layout_width="@dimen/spacing_xl"
                android:layout_height="@dimen/spacing_xl"
                android:background="@drawable/circle_background"
                android:layout_margin="@dimen/spacing_md"
                android:backgroundTint="@color/primary_blue" />

            <View
                android:id="@+id/pinDot2"
                android:layout_width="@dimen/spacing_xl"
                android:layout_height="@dimen/spacing_xl"
                android:background="@drawable/circle_background"
                android:layout_margin="@dimen/spacing_md"
                android:backgroundTint="@color/primary_blue" />

            <View
                android:id="@+id/pinDot3"
                android:layout_width="@dimen/spacing_xl"
                android:layout_height="@dimen/spacing_xl"
                android:background="@drawable/circle_background"
                android:layout_margin="@dimen/spacing_md"
                android:backgroundTint="@color/border_gray" />

            <View
                android:id="@+id/pinDot4"
                android:layout_width="@dimen/spacing_xl"
                android:layout_height="@dimen/spacing_xl"
                android:background="@drawable/circle_background"
                android:layout_margin="@dimen/spacing_md"
                android:backgroundTint="@color/border_gray" />
        </LinearLayout>

        <!-- Numeric Keypad -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="4"
            android:layout_marginBottom="@dimen/spacing_xl">

            <Button
                android:id="@+id/keypad1"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:text="1"
                android:textSize="@dimen/text_xl"
                android:layout_row="0"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/spacing_sm"
                android:backgroundTint="@color/background_light"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/keypad2"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:text="2"
                android:textSize="@dimen/text_xl"
                android:layout_row="0"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/spacing_sm"
                android:backgroundTint="@color/background_light"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/keypad3"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:text="3"
                android:textSize="@dimen/text_xl"
                android:layout_row="0"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/spacing_sm"
                android:backgroundTint="@color/background_light"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/keypad4"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:text="4"
                android:textSize="@dimen/text_xl"
                android:layout_row="1"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/spacing_sm"
                android:backgroundTint="@color/background_light"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/keypad5"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:text="5"
                android:textSize="@dimen/text_xl"
                android:layout_row="1"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/spacing_sm"
                android:backgroundTint="@color/background_light"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/keypad6"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:text="6"
                android:textSize="@dimen/text_xl"
                android:layout_row="1"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/spacing_sm"
                android:backgroundTint="@color/background_light"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/keypad7"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:text="7"
                android:textSize="@dimen/text_xl"
                android:layout_row="2"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/spacing_sm"
                android:backgroundTint="@color/background_light"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/keypad8"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:text="8"
                android:textSize="@dimen/text_xl"
                android:layout_row="2"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/spacing_sm"
                android:backgroundTint="@color/background_light"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/keypad9"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:text="9"
                android:textSize="@dimen/text_xl"
                android:layout_row="2"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/spacing_sm"
                android:backgroundTint="@color/background_light"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/keypad0"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:text="0"
                android:textSize="@dimen/text_xl"
                android:layout_row="3"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/spacing_sm"
                android:backgroundTint="@color/background_light"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/keypadDelete"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:text="⌫"
                android:textSize="@dimen/text_xl"
                android:layout_row="3"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/spacing_sm"
                android:backgroundTint="@color/background_light"
                android:textColor="@color/text_dark" />
        </GridLayout>

        <!-- Continue Offline Button -->
        <Button
            android:id="@+id/continueOfflineButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/continue_offline"
            style="@style/PrimaryButton"
            android:layout_marginBottom="@dimen/spacing_xl" />

        <!-- Security Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/secured_by_medilift"
            android:textSize="@dimen/text_xs"
            android:textColor="@color/text_light"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_lg" />

        <!-- Status Text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_ready"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_md" />

    </LinearLayout>
</ScrollView>
