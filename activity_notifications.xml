<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_lg"
        android:background="@color/background_white">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="@dimen/icon_size_md"
            android:layout_height="@dimen/icon_size_md"
            android:src="@android:drawable/ic_menu_back"
            android:contentDescription="Back"
            android:tint="@color/primary_blue"
            android:layout_marginEnd="@dimen/spacing_md" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/alerts"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:textColor="@color/primary_blue" />

        <Button
            android:id="@+id/markAllAsReadButton"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height_small"
            android:text="@string/mark_all_as_read"
            android:textSize="@dimen/text_xs"
            android:backgroundTint="@color/background_light"
            android:textColor="@color/primary_blue" />
    </LinearLayout>

    <!-- Subtitle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg"
        android:paddingTop="0">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prioritized_notifications"
            style="@style/SecondaryText"
            android:lineSpacingMultiplier="1.5" />
    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg"
            android:paddingTop="0">

            <!-- HIGH RISK Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/high_risk_section"
                style="@style/LabelText"
                android:textColor="@color/alert_red"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Abnormal Vitals -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/alert_red_light"
                app:cardCornerRadius="@dimen/corner_radius_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/icon_size_lg"
                            android:layout_height="@dimen/icon_size_lg"
                            android:src="@android:drawable/ic_dialog_alert"
                            android:contentDescription="Alert"
                            android:tint="@color/alert_red"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/abnormal_vitals"
                                style="@style/BodyText"
                                android:textStyle="bold"
                                android:textColor="@color/alert_red" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Patient: Amara Okafor"
                                style="@style/SecondaryText"
                                android:textColor="@color/alert_red" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOW"
                            style="@style/LabelText"
                            android:textColor="@color/alert_red" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/spo2_dropped"
                        style="@style/SecondaryText"
                        android:textColor="@color/alert_red"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <Button
                        android:id="@+id/viewPatientFileButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_small"
                        android:text="@string/view_patient_file"
                        android:textSize="@dimen/text_sm"
                        android:backgroundTint="@color/alert_red"
                        android:textColor="@color/text_white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Missed Dosage -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/alert_red_light"
                app:cardCornerRadius="@dimen/corner_radius_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/icon_size_lg"
                            android:layout_height="@dimen/icon_size_lg"
                            android:src="@android:drawable/ic_dialog_alert"
                            android:contentDescription="Alert"
                            android:tint="@color/alert_red"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/missed_dosage"
                                style="@style/BodyText"
                                android:textStyle="bold"
                                android:textColor="@color/alert_red" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Patient: Samuel Mkapa"
                                style="@style/SecondaryText"
                                android:textColor="@color/alert_red" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15 MIN AGO"
                            style="@style/LabelText"
                            android:textColor="@color/alert_red" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/scheduled_antibiotic"
                        style="@style/SecondaryText"
                        android:textColor="@color/alert_red"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <Button
                        android:id="@+id/logMedicationButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_small"
                        android:text="@string/log_medication"
                        android:textSize="@dimen/text_sm"
                        android:backgroundTint="@color/alert_red"
                        android:textColor="@color/text_white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FOLLOW-UP REMINDERS Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/follow_up_reminders"
                style="@style/LabelText"
                android:textColor="@color/primary_blue"
                android:layout_marginBottom="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_lg" />

            <!-- Post-op Review -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/background_light"
                app:cardCornerRadius="@dimen/corner_radius_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/icon_size_lg"
                            android:layout_height="@dimen/icon_size_lg"
                            android:src="@android:drawable/ic_menu_info_details"
                            android:contentDescription="Reminder"
                            android:tint="@color/primary_blue"
                            android:layout_marginEnd="@dimen/spacing_md" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/post_op_review"
                                style="@style/BodyText"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Patient: Elena Rodriguez"
                                style="@style/SecondaryText" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TODAY"
                            style="@style/LabelText" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/schedule_wound_dressing"
                        style="@style/SecondaryText"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <Button
                        android:id="@+id/scheduleNowButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_small"
                        android:text="@string/schedule_now"
                        android:textSize="@dimen/text_sm"
                        android:backgroundTint="@color/primary_blue"
                        android:textColor="@color/text_white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Status Text -->
            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/status_ready"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="@dimen/spacing_lg" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
