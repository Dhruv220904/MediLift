<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".AshaApp"
        android:allowBackup="true"
        android:icon="@android:drawable/ic_dialog_info"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.ProjectAsha">
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.SyncStatusActivity"
            android:exported="false" />
        <activity
            android:name=".ui.PatientHistoryActivity"
            android:exported="false" />
        <activity
            android:name=".ui.NotificationsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.EscalationActivity"
            android:exported="false" />
        <activity
            android:name=".ui.AiRiskResultActivity"
            android:exported="false" />
        <activity
            android:name=".ui.VisitActivity"
            android:exported="false" />
        <activity
            android:name=".ui.BeneficiaryActivity"
            android:exported="false" />
        <activity
            android:name=".ui.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
